#!/bin/bash
# kcs - KaisarCode Standards Validator
# Summary: Validates KaisarCode files against formatting and standards rules.
# Author:  KaisarCode
# Website: https://kaisarcode.com
# License: https://www.gnu.org/licenses/gpl-3.0.html

set -e
set -o pipefail

# Prints application usage help.
# @return 0 on success.
kc_kcs_help() {
    echo "Usage: kcs [options] <file|dir>..."
    echo
    echo "Options:"
    echo "  -type <t>        Force file type: sh|shell|c|cpp|php|md"
    echo "  -e, --exclude <p> Exclude path pattern"
    echo "  <file|dir>...    Validate one or more files or directories"
    echo "  -h, --help       Show help"
    echo
    echo "Supported file types:"
    echo "  Shell"
    echo "  C / C++"
    echo "  PHP"
    echo "  Markdown"
    echo
    echo "Examples:"
    echo "  kcs -type shell ./script.txt"
    echo "  kcs ./script.sh"
    echo "  kcs ./README.md"
    echo "  kcs ."
    echo
    echo "Dependencies:"
    echo "  shellcheck"
}

# Prints one error and the help text to standard error.
# @param $1 Error message
# @return 1 on failure.
kc_kcs_fail() {
    echo "Error: $1" >&2
    kc_kcs_help >&2
    return 1
}

# Prints failure details to standard error.
# @param message Error description.
# @return 1 on failure.
fail() {
    printf "\033[31m[FAIL]\033[0m %s\n" "$1" >&2
    return 1
}

# Prints success details to standard output.
# @param message Success description.
# @return 0 on success.
pass() {
    printf "\033[32m[PASS]\033[0m %s\n" "$1"
}

# Normalizes one CLI file type alias into the internal type name.
# @param $1 Raw type alias
# @return 0 on success, 1 on failure.
normalize_file_type() {
    case "$1" in
        sh|shell)
            echo "shell"
            return 0
            ;;
        c|cpp)
            echo "c"
            return 0
            ;;
        php)
            echo "php"
            return 0
            ;;
        md|markdown)
            echo "markdown"
            return 0
            ;;
    esac
    return 1
}

# Determines file type by inspecting shebangs or content.
# @param file Path to the file.
# @return string "shell", "c", "php", "markdown", or "unknown".
get_file_type() {
    if [ -n "$KC_KCS_FORCE_TYPE" ]; then
        echo "$KC_KCS_FORCE_TYPE"
        return 0
    fi
    local file="$1"
    [ -f "$file" ] && [ -r "$file" ] || return
    local sample
    sample=$(head -n 5 "$file" 2>/dev/null | tr -d '\0')
    if [[ "$sample" =~ ^#!.*(bash|sh) ]]; then echo "shell"; return; fi
    case "$file" in
        *.c|*.h|*.cpp|*.hpp) echo "c" ;;
        *.php) echo "php" ;;
        *.md) echo "markdown" ;;
        *) echo "unknown" ;;
    esac
}

# Validates that filenames use kebab-case instead of snake_case.
# Exception is made for files representing class names.
# @param file_path Path to the file.
# @return 0 on success, fails otherwise.
validate_filename() {
    local file_path="$1"
    local filename
    filename=$(basename "$file_path")
    local name="${filename%.*}"
    if [[ "$name" =~ [A-Z] ]]; then
        return 0
    fi
    if [[ "$name" == *"_"* ]]; then
        fail "$file_path: Filename must use hyphens '-' instead of underscores '_' to separate words."
    fi
}

# Validates whitespace, indentation, and blank lines.
# @param file_path Path to the file.
# @return 0 on success, fails otherwise.
validate_whitespace_and_limits() {
    local file_path="$1"
    local ftype
    local bad_line
    ftype=$(get_file_type "$file_path")
    if grep -q $'\t' "$file_path"; then fail "$file_path: Tabs are forbidden."; fi
    case "$ftype" in
        c|php)
            bad_line=$(awk '
                /^[[:space:]]*\/\*\*/ {
                    in_docblock = 1
                    next
                }
                in_docblock {
                    if (/\*\//) {
                        in_docblock = 0
                    }
                    next
                }
                /^[ ]+/ {
                    match($0, /^ +/)
                    if (RLENGTH % 4 != 0) { print NR; exit }
                }
            ' "$file_path" || true)
            ;;
        markdown)
            bad_line=$(awk '
                /^```/ {
                    in_fence = !in_fence
                    next
                }
                in_fence { next }
                /^[ ]+/ {
                    match($0, /^ +/)
                    if (RLENGTH % 4 != 0) { print NR; exit }
                }
            ' "$file_path" || true)
            ;;
        *)
            bad_line=$(awk '
                /^[ ]+/ {
                    match($0, /^ +/)
                    if (RLENGTH % 4 != 0) { print NR; exit }
                }
            ' "$file_path" || true)
            ;;
    esac
    if [ -n "$bad_line" ]; then
        fail "$file_path:$bad_line Indentation must use 4-space increments."
    fi
    bad_line=$(awk '
        /^[[:space:]]*$/ {
            blank_count++
            if (blank_count > 1) { print NR; exit }
            next
        }
        { blank_count = 0 }
    ' "$file_path" || true)
    if [ -n "$bad_line" ]; then
        fail "$file_path:$bad_line Multiple consecutive blank lines are forbidden."
    fi
    if [ -s "$file_path" ]; then
        local last_byte
        local last_two_bytes
        last_byte=$(tail -c 1 "$file_path" | od -An -t x1 | tr -d ' \n')
        last_two_bytes=$(tail -c 2 "$file_path" | od -An -t x1 | tr -d ' \n')
        if [ "$last_byte" != "0a" ]; then
            fail "$file_path: File must end with exactly one newline."
        fi
        if [ "$last_two_bytes" = "0a0a" ]; then
            fail "$file_path: File must end with exactly one newline."
        fi
    fi
    pass "$file_path: Whitespace verified."
}

# Ensures DocBlock lines do not exceed 80 chars.
# @param file_path Path to the file.
# @return 0 on success, fails otherwise.
validate_docblock_format() {
    local file_path="$1"
    local ftype
    ftype=$(get_file_type "$file_path")
    local bad_line
    case "$ftype" in
        shell)
            bad_line=$(awk '
                NR <= 20 { next }
                /^[[:space:]]*# / {
                    if (length($0) > 80) { print NR; exit }
                }
            ' "$file_path" || true)
            ;;
        c|php)
            bad_line=$(awk '
                NR <= 20 { next }
                /^[[:space:]]*\/\*\*/ {
                    if (NR > 1 && prev_nonblank != "" && prev_nonblank !~ /^[[:space:]]*#/) {
                        print NR
                        exit
                    }
                    in_docblock = 1
                    if (length($0) > 80) { print NR; exit }
                    next
                }
                in_docblock && /\*\// {
                    in_docblock = 0
                    prev_nonblank = $0
                    next
                }
                in_docblock && /^[[:space:]]*\*/ {
                    if (length($0) > 80) { print NR; exit }
                    next
                }
                /^[[:space:]]*#/ {
                    prev_nonblank = $0
                    next
                }
                /^[[:space:]]*$/ { prev_nonblank = ""; next }
                { prev_nonblank = $0 }
            ' "$file_path" || true)
            ;;
        *)
            bad_line=
            ;;
    esac
    if [ -n "$bad_line" ]; then
        fail "$file_path:$bad_line DocBlock exceeds 80 chars."
    fi
    pass "$file_path: DocBlock format verified."
}

# Requires one blank line before every DocBlock.
# @param file_path Path to the file.
# @param ftype File type identified.
# @return 0 on success.
validate_docblock_spacing() {
    local file_path="$1"
    local ftype="$2"
    local bad_line
    case "$ftype" in
        shell)
            bad_line=$(awk '
                BEGIN { in_header = 1 }
                NR == 1 && /^#!/ { next }
                in_header && /^[[:space:]]*#([[:space:]].*)?$/ { next }
                in_header && /^[[:space:]]*$/ {
                    in_header = 0
                    prev_blank = 1
                    next
                }
                /^[[:space:]]*# / {
                    if (NR > 1 && prev_blank == 0) {
                        print NR
                        exit
                    }
                    in_docblock = 1
                    next
                }
                /^[[:space:]]*$/ {
                    prev_blank = 1
                    in_docblock = 0
                    next
                }
                {
                    in_header = 0
                    prev_blank = 0
                    in_docblock = 0
                }
            ' "$file_path" || true)
            ;;
        c|php)
            bad_line=$(awk '
                /^[[:space:]]*\/\*\*/ {
                    if (NR > 1 && prev_blank == 0 && !prev_preproc) {
                        print NR
                        exit
                    }
                    in_docblock = 1
                    next
                }
                in_docblock {
                    if ($0 ~ /\*\//) {
                        in_docblock = 0
                    }
                    next
                }
                /^[[:space:]]*#/ {
                    prev_blank = 0
                    prev_preproc = 1
                    next
                }
                /^[[:space:]]*$/ {
                    prev_blank = 1
                    prev_preproc = 0
                    next
                }
                {
                    prev_blank = 0
                    prev_preproc = 0
                }
            ' "$file_path" || true)
            ;;
        *)
            bad_line=
            ;;
    esac
    if [ -n "$bad_line" ]; then
        fail "$file_path:$bad_line Missing blank line before DocBlock."
    fi
    pass "$file_path: DocBlock spacing verified."
}

# Validates objective shell-specific requirements.
# @param file_path Path to the file.
# @return 0 on success, fails otherwise.
validate_shell_rules() {
    local file_path="$1"
    local first_line
    first_line=$(head -n 1 "$file_path")
    case "$first_line" in
        '#!/bin/sh'|'#!/bin/bash')
            ;;
        *)
            fail "$file_path: Shell shebang must be /bin/sh or /bin/bash."
            ;;
    esac
    if ! shellcheck -x "$file_path" >/dev/null 2>&1; then
        fail "$file_path: shellcheck validation failed."
    fi
    pass "$file_path: Shell rules verified."
}

# Validates markdown-specific requirements.
# @param file_path Path to the file.
# @return 0 on success, fails otherwise.
validate_markdown_rules() {
    local file_path="$1"
    local h1_count
    h1_count=$(awk '
        /^```/ { in_fence = !in_fence; next }
        in_fence { next }
        /^# / { count++ }
        END { print count + 0 }
    ' "$file_path")
    if [ "$h1_count" -ne 1 ]; then
        fail "$file_path: Markdown files must contain exactly one H1."
    fi
    pass "$file_path: Markdown rules verified."
}

# Scans for forbidden internal comments while protecting DocBlocks.
# @param file_path Path to the file.
# @param ftype File type identified.
# @return 0 on success.
validate_no_internal_comments() {
    local file_path="$1"
    local ftype="$2"
    if [ "$ftype" = "shell" ]; then
        local bad_line
        bad_line=$(awk -v h="#" -v s=" " '
            NR <= 20 { next }
            $0 ~ "^"h {
                if (!in_docblock && $0 !~ "^"h" ([*@]|Summary:|Author:|Website:|License:|Email:|©|"s"|[A-Z])") {
                    print NR; exit
                }
                if ($0 ~ /@return/) seen_return = 1
                in_docblock = 1; next
            }
            index($0, s h) { print NR; exit }
            /^[[:space:]]*$/ { in_docblock = 0; seen_return = 0 }
            /^[a-z_]+[ ]*\(\)/ {
                if (in_docblock && !seen_return) { print NR; exit }
                in_docblock = 0; seen_return = 0
            }
            in_docblock {
                print NR; exit
            }
        ' "$file_path")
        [ -n "$bad_line" ] && fail "$file_path:$bad_line Forbidden internal comment or missing @return."
    elif [ "$ftype" = "c" ]; then
        local bad_line
        bad_line=$(awk -v sl="/" -v as="*" '
            function strip_strings(line,    out, i, ch, nextc, in_string, esc) {
                out = ""
                in_string = 0
                esc = 0
                for (i = 1; i <= length(line); i++) {
                    ch = substr(line, i, 1)
                    nextc = (i < length(line)) ? substr(line, i + 1, 1) : ""
                    if (!in_string) {
                        if (ch == "\"") {
                            in_string = 1
                            out = out " "
                        } else {
                            out = out ch
                        }
                        continue
                    }
                    if (esc) {
                        esc = 0
                        out = out " "
                        continue
                    }
                    if (ch == "\\") {
                        esc = 1
                        out = out " "
                        continue
                    }
                    if (ch == "\"") {
                        in_string = 0
                    }
                    out = out " "
                }
                return out
            }
            NR <= 20 { next }
            {
                scan = strip_strings($0)
            }
            index(scan, sl sl sl) { next }
            index(scan, sl sl) {
                if (NR > 20) { print NR; exit }
            }
            index(scan, sl as) && scan !~ /^[[:space:]]*\/\*\*/ {
                print NR; exit
            }
            scan ~ /^[[:space:]]*\/\*\*/ { in_docblock = 1 }
            in_docblock && /@return/ { seen_return = 1 }
            in_docblock && index(scan, as sl) {
                closing_line = NR
                next
            }
            closing_line && NR == closing_line + 1 {
                is_func = ($0 ~ /^[A-Za-z_][A-Za-z0-9_[:space:]\*]*\([^\)]*[;\{]?/ && $0 !~ /typedef/)
                if (!seen_return && is_func) { print NR - 1; exit }
                in_docblock = 0; seen_return = 0; closing_line = 0
            }
        ' "$file_path")
        [ -n "$bad_line" ] && fail "$file_path:$bad_line Forbidden internal comment or missing @return."
    fi
    pass "$file_path: No forbidden internal comments."
}

# Requires a DocBlock immediately before each function definition.
# @param file_path Path to the file.
# @param ftype File type identified.
# @return 0 on success.
validate_function_docblocks() {
    local file_path="$1"
    local ftype="$2"
    local bad_line
    if [ "$ftype" = "shell" ]; then
        bad_line=$(awk '
            /^[[:space:]]*# / {
                in_docblock = 1
                if ($0 ~ /@return/) {
                    seen_return = 1
                }
                next
            }
            /^[[:space:]]*$/ {
                in_docblock = 0
                seen_return = 0
                next
            }
            /^[a-z_][a-z0-9_]*[[:space:]]*\(\)[[:space:]]*\{/ {
                if (!in_docblock || !seen_return) { print NR; exit }
                in_docblock = 0
                seen_return = 0
                next
            }
            {
                in_docblock = 0
                seen_return = 0
            }
        ' "$file_path")
        [ -n "$bad_line" ] && fail "$file_path:$bad_line Missing function DocBlock."
    elif [ "$ftype" = "c" ] || [ "$ftype" = "php" ]; then
        bad_line=$(awk '
            function is_control_line(line) {
                return line ~ /^(if|for|while|switch)[[:space:]]*\(/
            }
            function is_function_start(line) {
                return line ~ /^[A-Za-z_][A-Za-z0-9_[:space:]\*]*\([^\)]*$/ &&
                    line !~ /;[[:space:]]*$/ &&
                    line !~ /=/ &&
                    !is_control_line(line)
            }
            function is_function_signature(line) {
                return line ~ /^[A-Za-z_][A-Za-z0-9_[:space:]\*]*\([^;]*\)[[:space:]]*$/ &&
                    line !~ /=/ &&
                    !is_control_line(line)
            }
            function is_function_single(line) {
                return line ~ /^[A-Za-z_][A-Za-z0-9_[:space:]\*]*\([^;]*\)[[:space:]]*\{/ &&
                    line !~ /=/ &&
                    !is_control_line(line)
            }
            /^[[:space:]]*\/\*\*/ {
                in_docblock = 1
                if ($0 ~ /@return/) {
                    seen_return = 1
                }
                next
            }
            in_docblock {
                if ($0 ~ /@return/) {
                    seen_return = 1
                }
                if ($0 ~ /\*\//) {
                    in_docblock = 0
                    docblock_ready = 1
                }
                next
            }
            /^[[:space:]]*$/ {
                docblock_ready = 0
                seen_return = 0
                next
            }
            /^[[:space:]]*#/ { next }
            pending_function && /^[[:space:]]*\{/ {
                if (!docblock_ready || !seen_return) { print pending_line; exit }
                pending_function = 0
                docblock_ready = 0
                seen_return = 0
                next
            }
            pending_function {
                if ($0 ~ /;[[:space:]]*$/) {
                    pending_function = 0
                    docblock_ready = 0
                    seen_return = 0
                    next
                }
                if ($0 ~ /\)[[:space:]]*\{/) {
                    if (!docblock_ready || !seen_return) { print pending_line; exit }
                    pending_function = 0
                    docblock_ready = 0
                    seen_return = 0
                    next
                }
                next
            }
            is_function_single($0) {
                if (!docblock_ready || !seen_return) { print NR; exit }
                docblock_ready = 0
                seen_return = 0
                next
            }
            is_function_start($0) {
                pending_function = 1
                pending_line = NR
                next
            }
            is_function_signature($0) {
                pending_function = 1
                pending_line = NR
                next
            }
            {
                docblock_ready = 0
                seen_return = 0
            }
        ' "$file_path")
        [ -n "$bad_line" ] && fail "$file_path:$bad_line Missing function DocBlock or @return."
    fi
    pass "$file_path: Function DocBlocks verified."
}

# Expands files and directories into a flat validation list.
# @param args List of files or directories to validate.
# @return 0 on success.
collect_artifacts() {
    local arg
    for arg in "$@"; do
        if [ -f "$arg" ]; then
            printf '%s\0' "$arg"
            continue
        fi
        if [ -d "$arg" ]; then
            local find_cmd=(find "$arg" -mindepth 1)
            find_cmd+=(\( -type d \( -path '*/lib/inc' -o -path '*/lib/obj' -o -path '*/vendor' -o -path '*/vendors' -o -path '*/third_party' -o -path '*/third-party' \) \) -prune -o)
            find_cmd+=(\( -type d -name '.*' -o -type f -name '.*' \) -prune -o)
            for exc in "${KC_KCS_EXCLUDES[@]}"; do
                find_cmd+=(\( -path "*$exc*" \) -prune -o)
            done
            find_cmd+=(-type f -print0)
            "${find_cmd[@]}"
        fi
    done
}

# Ensures no numbered or ornamented outputs.
# @param file_path Path to the file.
# @param ftype File type identified.
# @return 0 on success, fails otherwise.
validate_no_numbered_or_ornamented_outputs() {
    local file_path="$1"
    local ftype="$2"
    local bad_line
    local AWK_HELPERS='
        function has_ornament(str) {
            if (str ~ /(===|---|[\*]{3}|___|###|[\+]{3}|~~~)/) return 1
            if (str ~ /(==|--|[\*]{2}|__|##|[\+]{2}|~~)[[:space:]]*[a-zA-Z0-9_[:space:]]+[[:space:]]*(==|--|[\*]{2}|__|##|[\+]{2}|~~)/) return 1
            if (str ~ /(->|=>|-->|==>|<-|<=|<->|<==>)/) return 1
            gsub(/\xc2\xa9/, "", str)
            if (str ~ /[^\x00-\x7F]/) return 1
            return 0
        }
        function check_line_for_ornaments(line,    n, parts, i) {
            n = split(line, parts, /[\x27\x22\x60]/)
            for (i = 2; i <= n; i += 2) {
                if (has_ornament(parts[i])) return 1
            }
            return 0
        }
    '
    case "$ftype" in
        markdown)
            bad_line=$(awk '
                '"$AWK_HELPERS"'
                /^```/ { in_fence = !in_fence; next }
                in_fence { next }
                /^[[:space:]]*#+[[:space:]]+/ {
                    heading = $0
                    sub(/^[[:space:]]*#+[[:space:]]+/, "", heading)
                    if (heading ~ /^[0-9]+[\.\)]/) { print NR; exit }
                    if (has_ornament(heading)) { print NR; exit }
                }
            ' "$file_path")
            if [ -n "$bad_line" ]; then
                fail "$file_path:$bad_line Headings must not be numbered or contain ornaments."
            fi
            ;;
        shell)
            bad_line=$(awk '
                '"$AWK_HELPERS"'
                /^[[:space:]]*#/ {
                    comment = $0
                    sub(/^[[:space:]]*#/, "", comment)
                    if (has_ornament(comment)) { print NR; exit }
                }
                /^[[:space:]]*(echo|printf|log_[a-z0-9_]+|kc_log_[a-z0-9_]+)[[:space:]]+/ {
                    if ($0 ~ /[\x27\x22\x60][[:space:]]*(\\[a-zA-Z])*[[:space:]]*[0-9]+[\.\)]/) { print NR; exit }
                    if (check_line_for_ornaments($0)) { print NR; exit }
                }
            ' "$file_path")
            if [ -n "$bad_line" ]; then
                fail "$file_path:$bad_line Print/echo statements and comments must not contain numbered messages or ornaments."
            fi
            ;;
        c|php)
            bad_line=$(awk '
                '"$AWK_HELPERS"'
                /^[[:space:]]*\/\*/ { in_comment = 1; comment = $0; sub(/^[[:space:]]*\/\*/, "", comment); if (has_ornament(comment)) { print NR; exit } }
                /^[[:space:]]*\*\// { in_comment = 0; comment = $0; sub(/^[[:space:]]*\*\//, "", comment); if (has_ornament(comment)) { print NR; exit } }
                in_comment && /^[[:space:]]*\*/ { comment = $0; sub(/^[[:space:]]*\*/, "", comment); if (has_ornament(comment)) { print NR; exit } }
                /^[[:space:]]*\/\// { comment = $0; sub(/^[[:space:]]*\/\//, "", comment); if (has_ornament(comment)) { print NR; exit } }
                /(printf|fprintf|sprintf|snprintf|kc_log|log_[a-z0-9_]+|echo)[[:space:]]*\(/ {
                    if ($0 ~ /\([^\x22]*\x22[[:space:]]*(\\[a-zA-Z])*[[:space:]]*[0-9]+[\.\)]/) { print NR; exit }
                    if (check_line_for_ornaments($0)) { print NR; exit }
                }
                /^[[:space:]]*echo[[:space:]]+/ {
                    if ($0 ~ /[\x27\x22\x60][[:space:]]*(\\[a-zA-Z])*[[:space:]]*[0-9]+[\.\)]/) { print NR; exit }
                    if (check_line_for_ornaments($0)) { print NR; exit }
                }
            ' "$file_path")
            if [ -n "$bad_line" ]; then
                fail "$file_path:$bad_line C/PHP prints/logs and comments must not contain numbered messages or ornaments."
            fi
            ;;
    esac
    pass "$file_path: Numbered and ornamented output rules verified."
}

# Validates that files begin with the KaisarCode header block.
# @param file_path Path to the file.
# @param ftype File type identified.
# @return 0 on success, fails otherwise.
kc_validate_header() {
    local file_path="$1"
    local ftype="$2"
    local bad_line
    case "$ftype" in
        shell)
            bad_line=$(awk '
                NR == 1 && /^#!/ { next }
                NR == 2 && /^# / { next }
                NR == 3 && /^# Summary:/ { next }
                NR == 4 && /^# Author:/ { next }
                NR == 5 && /^# Website:/ { next }
                NR == 6 && /^# License:/ { next }
                NR >= 2 && NR <= 6 { print NR; exit }
            ' "$file_path" || true)
            if [ -n "$bad_line" ]; then
                fail "$file_path:$bad_line Missing or malformed KaisarCode header."
            fi
            ;;
        c|php)
            bad_line=$(awk '
                NR == 1 && /^[[:space:]]*\/\*\*/ { next }
                NR == 2 && /^ \*/ { next }
                NR == 3 && /^ \* Summary:/ { next }
                NR == 4 && /^ \*$/ { next }
                NR == 5 && /^ \* Author:/ { next }
                NR == 6 && /^ \* Website:/ { next }
                NR == 7 && /^ \* License:/ { next }
                NR == 8 && /^ \*\// { next }
                NR >= 1 && NR <= 8 { print NR; exit }
            ' "$file_path" || true)
            if [ -n "$bad_line" ]; then
                fail "$file_path:$bad_line Missing or malformed KaisarCode header."
            fi
            ;;
    esac
    pass "$file_path: KaisarCode header verified."
}

# Main entry point for the validator lifecycle.
# @param args List of files or directories to validate.
# @return 0 on success.
run_validator() {
    local artifacts=()
    local artifact
    while IFS= read -r -d '' artifact; do
        artifacts+=("$artifact")
    done < <(collect_artifacts "$@")
    [ "${#artifacts[@]}" -gt 0 ] || kc_kcs_fail "No valid files or directories were provided." || return 1
    for artifact in "${artifacts[@]}"; do
        local ftype
        ftype=$(get_file_type "$artifact")
        [ "$ftype" = "unknown" ] && continue
        if [[ "$(basename "$artifact")" == "CHANGELOG.md" ]]; then
            continue
        fi
        validate_filename "$artifact"
        kc_validate_header "$artifact" "$ftype"
        validate_whitespace_and_limits "$artifact"
        validate_no_internal_comments "$artifact" "$ftype"
        validate_docblock_spacing "$artifact" "$ftype"
        validate_function_docblocks "$artifact" "$ftype"
        validate_docblock_format "$artifact"
        validate_no_numbered_or_ornamented_outputs "$artifact" "$ftype"
        case "$ftype" in
            shell)
                validate_shell_rules "$artifact"
                ;;
            markdown)
                validate_markdown_rules "$artifact"
                ;;
        esac
    done
}

# Main entry point.
# @return 0 on success, 1 on failure.
main() {
    local force_type=""
    local excludes=()

    if [ -f ".kcsignore" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            [[ "$line" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${line// /}" ]] && continue
            excludes+=("$line")
        done < ".kcsignore"
    fi

    while [ "$#" -gt 0 ]; do
        case "$1" in
            -h|--help)
                kc_kcs_help
                return 0
                ;;
            -type)
                shift
                [ -n "$1" ] || kc_kcs_fail "Missing value for -type." || return 1
                force_type="$(normalize_file_type "$1")" || \
                kc_kcs_fail "Invalid value for -type." || return 1
                ;;
            -e|--exclude)
                shift
                [ -n "$1" ] || kc_kcs_fail "Missing value for --exclude." || return 1
                excludes+=("$1")
                ;;
            *)
                break
                ;;
        esac
        shift
    done

    [ "$#" -gt 0 ] || set -- "."
    export KC_KCS_FORCE_TYPE="$force_type"
    KC_KCS_EXCLUDES=("${excludes[@]}")
    run_validator "$@"
}

main "$@"
